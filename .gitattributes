# Enforce deterministic line endings across the project
* text=auto

# Source and docs
*.js text eol=lf
*.json text eol=lf
*.md text eol=lf
*.html text eol=lf
*.css text eol=lf
*.txt text eol=lf
*.xml text eol=lf
*.xhtml text eol=lf
*.yml text eol=lf
*.yaml text eol=lf

# Keep binaries untouched
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.xpi binary
*.zip binary
